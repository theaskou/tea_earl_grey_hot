{
    "version": 2,
    "headers": [
        {
            "source": "/public/assets/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "/public/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "app.js"
        }
    ]
}